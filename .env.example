# Variables para docker-compose (raíz del proyecto)
# Copiá este archivo a .env y completá los valores.
# El usuario de MySQL dentro de docker-compose es siempre "root" (ver docker-compose.yml).

DB_PASSWORD=tu_password
DB_NAME=ticketapp

JWT_SECRET=cambia_esto_por_una_clave_secreta
JWT_EXPIRATION_HOURS=24

# URL de la API que el frontend usa en build time (Vite la incrusta en el bundle)
VITE_API_BASE_URL=http://localhost:8080/api
