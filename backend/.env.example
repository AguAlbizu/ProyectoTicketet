# Base de datos MySQL
DB_USER=root
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ticketapp

# JWT — cambiá esto por una clave larga y aleatoria en producción
JWT_SECRET=cambia_esto_por_una_clave_secreta
JWT_EXPIRATION_HOURS=24

# Servidor
PORT=8080

# Email (opcional — requerido solo si se activa el cliente de email)
EMAIL_API_URL=https://api.tu-proveedor-email.com/send
EMAIL_API_KEY=tu_api_key
EMAIL_FROM=noreply@ticketapp.com
